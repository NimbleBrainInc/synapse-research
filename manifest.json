{
  "manifest_version": "0.4",
  "name": "@nimblebraininc/synapse-research",
  "version": "0.2.0",
  "description": "Research runs powered by MCP tasks. Kick off long-running research and track progress in real time.",
  "author": {
    "name": "NimbleBrain Inc."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleBrainInc/synapse-research"
  },
  "server": {
    "type": "python",
    "entry_point": "mcp_research.server",
    "mcp_config": {
      "command": "python",
      "args": [
        "-m",
        "mcp_research.server"
      ],
      "env": {
        "ANTHROPIC_API_KEY": "${user_config.anthropic_api_key}",
        "TAVILY_API_KEY": "${user_config.tavily_api_key}",
        "OPENAI_API_KEY": "${user_config.openai_api_key}",
        "RETRIEVER": "tavily",
        "FAST_LLM": "anthropic:claude-haiku-4-5",
        "SMART_LLM": "anthropic:claude-sonnet-4-6",
        "STRATEGIC_LLM": "anthropic:claude-sonnet-4-6",
        "EMBEDDING": "openai:text-embedding-3-small"
      }
    }
  },
  "user_config": {
    "anthropic_api_key": {
      "type": "string",
      "title": "Anthropic API Key",
      "description": "Claude LLM used by GPT-Researcher for planning and report writing. Get a key at console.anthropic.com.",
      "sensitive": true,
      "required": true
    },
    "tavily_api_key": {
      "type": "string",
      "title": "Tavily API Key",
      "description": "Web search provider for research queries. Get a key at tavily.com.",
      "sensitive": true,
      "required": true
    },
    "openai_api_key": {
      "type": "string",
      "title": "OpenAI API Key",
      "description": "Used only for embeddings (text-embedding-3-small). Get a key at platform.openai.com.",
      "sensitive": true,
      "required": true
    }
  },
  "tools": [
    {
      "name": "start_research",
      "description": "Run a research task on a query. MUST be invoked with MCP task augmentation. Returns a CreateTaskResult immediately; the final markdown report is retrieved via tasks/result after the task completes."
    }
  ],
  "_meta": {
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "filesystem": "write",
        "network": "full",
        "environment": "read",
        "subprocess": "none",
        "native": "none"
      }
    },
    "ai.nimblebrain/host": {
      "host_version": "1.0",
      "name": "Research",
      "icon": "search",
      "category": "research",
      "placements": [
        {
          "slot": "sidebar.apps",
          "resourceUri": "ui://research/main",
          "route": "@nimblebraininc/synapse-research",
          "label": "Research",
          "icon": "search"
        }
      ],
      "briefing": {
        "priority": "normal",
        "facets": [
          {
            "name": "active_runs",
            "label": "Active",
            "type": "activity",
            "entity": "research_run",
            "query": {
              "run_status": "working"
            },
            "metric": "count",
            "description": "Research runs currently in progress"
          },
          {
            "name": "recent_completed",
            "label": "Completed",
            "type": "delta",
            "entity": "research_run",
            "query": {
              "run_status": "completed",
              "completed_at": {
                "$gte": "${period.since}"
              }
            },
            "metric": "count",
            "description": "Runs completed in this period"
          }
        ]
      }
    },
    "ai.nimblebrain/upjack": {
      "upjack_version": "0.1",
      "namespace": "apps/research",
      "display": {
        "name": "Research",
        "icon": "search",
        "category": "research"
      },
      "entities": [
        {
          "name": "research_run",
          "plural": "research_runs",
          "schema": "schemas/research_run.schema.json",
          "prefix": "rr",
          "index": true,
          "tools": [
            "get",
            "list",
            "search",
            "delete"
          ]
        }
      ],
      "skills": [
        {
          "source": "bundled",
          "path": "skills/research-runs/SKILL.md"
        }
      ],
      "views": [
        {
          "name": "active",
          "entity": "research_run",
          "description": "Runs currently in progress",
          "filter": "$.run_status == 'working'",
          "sort": "-started_at"
        },
        {
          "name": "recent",
          "entity": "research_run",
          "description": "Recently completed, failed, or cancelled runs",
          "filter": "$.run_status != 'working'",
          "sort": "-completed_at"
        }
      ],
      "context": "context.md"
    }
  }
}
